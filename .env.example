# ============================================================
# World Cup 2026 — Environment Variables Example
# Copy this file to .env.local and fill in your real values.
# ============================================================

# ---- Supabase (public, safe for client) ----
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=YOUR_PUBLISHABLE_KEY

# ---- Supabase (server-only, NEVER expose to client) ----
# Used by sync scripts and server actions only
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY
SUPABASE_DB_URL=postgresql://postgres:PASSWORD@db.YOUR-PROJECT.supabase.co:5432/postgres

# ---- API-Football (server-only) ----
# https://www.api-football.com/
API_FOOTBALL_KEY=YOUR_API_FOOTBALL_KEY
API_FOOTBALL_BASE_URL=https://v3.football.api-sports.io

# ---- Tournament info ----
NEXT_PUBLIC_WC_TOURNAMENT_ID=1
NEXT_PUBLIC_WC_SEASON=2026
